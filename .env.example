# ==============================================================================
# Ideation GOAT Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and populate with your credentials.
# Note: Real keys are ignored during local core-engine runs, but required for platform deployment.

# --- VECTOR DATABASE CONFIGURATIONS (ChromaDB) ---
CHROMA_DB_PATH=./chroma_data
CHROMADB_COLLECTION_NAME=ideation_goat_vectors
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# --- LLM PLATFORM ROUTER KEYS ---
LLM_PROVIDER=gemini                               # Options: gemini, openai, anthropic
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_NAME=gemini-3.1-flash-lite             # Default model name for code translation

# --- DOMAIN 1: FRAMEWORKS & SOURCE CONTROL API INTEGRATIONS ---
# GitHub REST/GraphQL API Configuration
GITHUB_API_TOKEN=your_github_personal_access_token_here

# GitLab Enterprise and Open Source API Configuration
GITLAB_API_BASE_URL=https://gitlab.com/api/v4     # Base URL for GitLab API endpoints
GITLAB_API_TOKEN=your_gitlab_personal_access_token_here

# Hacker News sentiment and developer trend tracking endpoint
HACKER_NEWS_API_BASE_URL=https://hacker-news.firebaseio.com/v0

# --- DOMAIN 2: RESEARCH & ACADEMIC API INTEGRATIONS ---
# ArXiv Open API Base Endpoint
ARXIV_API_BASE_URL=http://export.arxiv.org/api/query

# Academic and Patent APIs (Semantic Scholar and arXiv are keyless by default)
UNPAYWALL_EMAIL=your_email_for_unpaywall_here
GOOGLE_PATENTS_API_KEY=your_serpapi_google_patents_api_key_here
GOOGLE_SCHOLAR_API_KEY=your_serpapi_google_scholar_api_key_here
